<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox alignment="CENTER_LEFT"
      spacing="20.0"
      styleClass="navbar-container"
      stylesheets="@../styles/styles.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.ies.fenix.client.controller.NavbarController">

    <padding>
        <Insets top="30.0" right="30.0" bottom="18.0" left="30.0"/>
    </padding>

    <!-- Flechas -->
    <Button styleClass="nav-button">
        <graphic>
            <FontIcon iconLiteral="mdi2c-chevron-left" iconSize="22" iconColor="#9A9A9A"/>
        </graphic>
    </Button>

    <Button styleClass="nav-button">
        <graphic>
            <FontIcon iconLiteral="mdi2c-chevron-right" iconSize="22" iconColor="#9A9A9A"/>
        </graphic>
    </Button>

    <!-- Navegación -->
    <Hyperlink fx:id="marketplace" text="MARKET PLACE" onAction="#goMarketplace"/>
    <Hyperlink fx:id="library" text="LIBRARY" onAction="#goLibrary"/>
    <Hyperlink fx:id="username" text="USERNAME" onAction="#goProfile"/>

    <Region HBox.hgrow="ALWAYS"/>

    <!-- Botón crear -->
    <Button text="Create your own visual novel"
            styleClass="main-action-button"
            onAction="#goUpload"/>

    <!-- Perfil -->
    <StackPane prefWidth="40" prefHeight="40" styleClass="profile-wrapper">
        <FontIcon fx:id="topProfileIcon"
                  iconLiteral="mdi2a-account-outline"
                  iconSize="22"
                  iconColor="#B8B8B8"/>
        <ImageView fx:id="topProfileImage"
                   fitWidth="40"
                   fitHeight="40"
                   preserveRatio="true"
                   visible="false"/>
    </StackPane>

    <Label styleClass="dropdown-icon">
        <graphic>
            <FontIcon iconLiteral="mdi2c-chevron-down" iconSize="18" iconColor="#9A9A9A"/>
        </graphic>
    </Label>

</HBox>
