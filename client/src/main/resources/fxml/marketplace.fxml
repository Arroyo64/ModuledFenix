<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="root"
            prefHeight="800.0"
            prefWidth="1300.0"
            stylesheets="@../styles/styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.ies.fenix.client.controller.MarketplaceController">

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="main-scroll">
            <content>
                <VBox spacing="35.0" styleClass="content-container">
                    <padding>
                        <Insets top="45.0" right="30.0" bottom="30.0" left="30.0"/>
                    </padding>

                    <VBox spacing="18.0">
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="5.0">
                                <Label text="Latest released" styleClass="section-title"/>
                                <Label text="New histories to play!" styleClass="section-subtitle"/>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <TextField fx:id="searchField"
                                       promptText="Search"
                                       prefWidth="420.0"
                                       styleClass="search-field"/>
                        </HBox>

                        <ScrollPane fitToHeight="true"
                                    fitToWidth="false"
                                    hbarPolicy="AS_NEEDED"
                                    vbarPolicy="NEVER"
                                    pannable="true"
                                    prefViewportHeight="250.0"
                                    styleClass="horizontal-games-scroll">
                            <content>
                                <HBox fx:id="latestReleasedContainer"
                                      spacing="24.0"
                                      styleClass="games-row"/>
                            </content>
                        </ScrollPane>
                    </VBox>

                    <VBox spacing="18.0">
                        <VBox spacing="5.0">
                            <Label text="Recommendations" styleClass="section-title"/>
                            <Label text="Based on you like to play" styleClass="section-subtitle"/>
                        </VBox>

                        <ScrollPane fitToHeight="true"
                                    fitToWidth="false"
                                    hbarPolicy="AS_NEEDED"
                                    vbarPolicy="NEVER"
                                    pannable="true"
                                    prefViewportHeight="250.0"
                                    styleClass="horizontal-games-scroll">
                            <content>
                                <HBox fx:id="recommendationsContainer"
                                      spacing="24.0"
                                      styleClass="games-row"/>
                            </content>
                        </ScrollPane>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>