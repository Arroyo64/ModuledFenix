            </padding>

            <Button styleClass="nav-button">
                <graphic>
                    <FontIcon iconLiteral="mdi2c-chevron-left" iconSize="22" iconColor="#9A9A9A"/>
                </graphic>
            </Button>

            <Button styleClass="nav-button">
                <graphic>
                    <FontIcon iconLiteral="mdi2c-chevron-right" iconSize="22" iconColor="#9A9A9A"/>
                </graphic>
            </Button>

            <Hyperlink fx:id="marketplace" text="MARKET PLACE" styleClass="tab-active" onAction="#reloadView"/>
            <Hyperlink fx:id="library" text="LIBRARY" styleClass="tab-inactive" onAction="#switchToLibraryScene"/>
            <Hyperlink fx:id="username" text="USERNAME" styleClass="tab-inactive" onAction="#switchProfileScene"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Create your own visual novel" styleClass="main-action-button"/>

            <StackPane prefWidth="40"
                       prefHeight="40"
                       minWidth="40"
                       minHeight="40"
                       maxWidth="40"
                       maxHeight="40"
                       styleClass="profile-wrapper">

                <!-- Icono por defecto -->
                <FontIcon fx:id="topProfileIcon"
                          iconLiteral="mdi2a-account-outline"
                          iconSize="22"
                          iconColor="#B8B8B8"/>

                <!-- Imagen -->
                <ImageView fx:id="topProfileImage"
                           fitWidth="40"
                           fitHeight="40"
                           preserveRatio="true"
                           visible="false"/>
            </StackPane>

            <Label styleClass="dropdown-icon">
                <graphic>
                    <FontIcon iconLiteral="mdi2c-chevron-down" iconSize="18" iconColor="#9A9A9A"/>
                </graphic>
            </Label>
        </HBox>
    </top>

