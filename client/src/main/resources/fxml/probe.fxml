<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="root" prefHeight="800.0" prefWidth="1300.0" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.ies.fenix.client.controller.MarketplaceController">

    <!-- TODO: top intacto, no tocado -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="content-container">
            <padding>
                <Insets bottom="0.0" left="30.0" right="30.0" top="30.0" />
            </padding>

            <Button styleClass="nav-button">
                <graphic>
                    <FontIcon iconColor="#9A9A9A" iconLiteral="mdi2c-chevron-left" iconSize="22" />
                </graphic>
            </Button>

            <Button styleClass="nav-button">
                <graphic>
                    <FontIcon iconColor="#9A9A9A" iconLiteral="mdi2c-chevron-right" iconSize="22" />
                </graphic>
            </Button>

            <Hyperlink fx:id="marketplace" onAction="#reloadView" styleClass="tab-active" text="MARKET PLACE" />
            <Hyperlink fx:id="library" onAction="#switchToLibraryScene" styleClass="tab-inactive" text="LIBRARY" />
            <Hyperlink fx:id="username" onAction="#switchProfileScene" styleClass="tab-inactive" text="USERNAME" />

            <Region HBox.hgrow="ALWAYS" />

            <Button onAction="#switchToUploadGameScene" styleClass="main-action-button" text="Create your own visual novel" />

            <StackPane maxHeight="40" maxWidth="40" minHeight="40" minWidth="40" prefHeight="40" prefWidth="40" styleClass="profile-wrapper">

                <FontIcon fx:id="topProfileIcon" iconColor="#B8B8B8" iconLiteral="mdi2a-account-outline" iconSize="22" />

                <ImageView fx:id="topProfileImage" fitHeight="40" fitWidth="40" preserveRatio="true" visible="false" />
            </StackPane>

            <Label styleClass="dropdown-icon">
                <graphic>
                    <FontIcon iconColor="#9A9A9A" iconLiteral="mdi2c-chevron-down" iconSize="18" />
                </graphic>
            </Label>
        </HBox>
    </top>

    <!-- SOLO cambiamos esto -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll" vbarPolicy="AS_NEEDED">
            <content>
                <VBox prefWidth="1282.0" spacing="35.0" styleClass="content-container">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="15.0" />
                    </padding>

                    <!-- Latest released -->
                    <VBox spacing="18.0">
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="5.0">
                                <Label styleClass="section-title" text="Latest released" />
                                <Label styleClass="section-subtitle" text="New histories to play!" />
                            </VBox>

                            <Region HBox.hgrow="ALWAYS" />
      
                            <TextField fx:id="searchField" prefWidth="420.0" promptText="Search" styleClass="search-field" />
                        </HBox>

                        <ScrollPane fitToHeight="true" fitToWidth="false" hbarPolicy="AS_NEEDED" pannable="true" prefViewportHeight="250.0" styleClass="horizontal-games-scroll" vbarPolicy="NEVER">
                            <content>
                                <HBox fx:id="latestReleasedContainer" spacing="24.0" styleClass="games-row" />
                            </content>
                        </ScrollPane>
                    </VBox>

                    <!-- Recommendations -->
                    <VBox spacing="18.0">
                        <VBox spacing="5.0">
                            <Label styleClass="section-title" text="Recommendations" />
                            <Label styleClass="section-subtitle" text="Based on you like to play" />
                        </VBox>

                        <ScrollPane fitToHeight="true" fitToWidth="false" hbarPolicy="AS_NEEDED" pannable="true" prefViewportHeight="250.0" styleClass="horizontal-games-scroll" vbarPolicy="NEVER">
                            <content>
                                <HBox fx:id="recommendationsContainer" spacing="24.0" styleClass="games-row" />
                            </content>
                        </ScrollPane>
                    </VBox>

                    <!-- Offers -->
                    <VBox spacing="18.0">
                        <VBox spacing="5.0">
                            <Label styleClass="section-title" text="Offers" />
                            <Label styleClass="section-subtitle" text="More stories to discover" />
                        </VBox>

                        <ScrollPane fitToHeight="true" fitToWidth="false" hbarPolicy="AS_NEEDED" pannable="true" prefViewportHeight="250.0" styleClass="horizontal-games-scroll" vbarPolicy="NEVER">
                            <content>
                                <HBox fx:id="offersContainer" spacing="24.0" styleClass="games-row" />
                            </content>
                        </ScrollPane>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
