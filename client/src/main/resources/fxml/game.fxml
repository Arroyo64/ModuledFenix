<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>


<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.layout.StackPane?>
<BorderPane fx:id="root"
            prefHeight="850.0"
            prefWidth="1400.0"
            styleClass="game-root"
            stylesheets="@../styles/styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.ies.fenix.client.controller.GameController">

    <!-- TOP NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20.0"
              styleClass="content-container">

            <padding>
                <Insets top="30.0" right="30.0" bottom="0.0" left="30.0"/>
            </padding>

<!--            <Button text="&lt;" styleClass="nav-button"/>-->
<!--            <Button text="&gt;" styleClass="nav-button"/>-->
            <Button styleClass="nav-button">
                <graphic>
                    <FontIcon iconLiteral="mdi2c-chevron-left" iconSize="22" iconColor="#9A9A9A"/>
                </graphic>
            </Button>

            <Button styleClass="nav-button">
                <graphic>
                    <FontIcon iconLiteral="mdi2c-chevron-right" iconSize="22" iconColor="#9A9A9A"/>
                </graphic>
            </Button>
            <!--Cambiado por icon-->

            <Hyperlink text="MARKET PLACE"
                       styleClass="tab-inactive"
                       onAction="#switchToMarketplaceScene"/>

            <Hyperlink text="LIBRARY"
                       styleClass="tab-active"
                       onAction="#switchToLibraryScene"/>

            <Hyperlink fx:id="username"
                       text="USERNAME"
                       styleClass="tab-inactive"
                       onAction="#switchProfileScene"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Create your own visual novel"
                    styleClass="main-action-button"
                    onAction="#switchToUploadGameScene"/>

            <StackPane prefWidth="40"
                       prefHeight="40"
                       minWidth="40"
                       minHeight="40"
                       maxWidth="40"
                       maxHeight="40"
                       styleClass="profile-wrapper">

                <!-- Icono por defecto -->
                <FontIcon fx:id="topProfileIcon"
                          iconLiteral="mdi2a-account-outline"
                          iconSize="22"
                          iconColor="#B8B8B8"/>

                <!-- Imagen -->
                <ImageView fx:id="topProfileImage"
                           fitWidth="40"
                           fitHeight="40"
                           preserveRatio="true"
                           visible="false"/>
            </StackPane>
            <Label styleClass="dropdown-icon">
                <graphic>
                    <FontIcon iconLiteral="mdi2c-chevron-down" iconSize="18" iconColor="#9A9A9A"/>
                </graphic>
            </Label>
            <!--                        Cambiado por icon-->
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="main-scroll">

            <content>
                <VBox spacing="0.0"
                      styleClass="game-container">

                    <!-- BIG BANNER -->
                    <HBox alignment="CENTER"
                          prefHeight="360.0"
                          styleClass="game-banner-wrapper">

                        <ImageView fitHeight="320.0"
                                   fitWidth="1200.0"
                                   preserveRatio="false"
                                   styleClass="game-banner-image"/>
                    </HBox>

                    <!-- LOWER CONTENT -->
                    <GridPane styleClass="game-main-grid"
                              hgap="0.0"
                              vgap="0.0">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="68.0"/>
                            <ColumnConstraints percentWidth="32.0"/>
                        </columnConstraints>

                        <!-- LEFT PANEL -->
                        <VBox GridPane.columnIndex="0"
                              spacing="24.0"
                              styleClass="game-left-panel">

                            <padding>
                                <Insets top="35.0"
                                        right="40.0"
                                        bottom="35.0"
                                        left="40.0"/>
                            </padding>

                            <Label text="GAME"
                                   styleClass="game-main-quote"/>

                            <VBox spacing="18.0">

                                <Label wrapText="true"
                                       styleClass="game-description"
                                       text="Lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est."/>

                                <Label wrapText="true"
                                       styleClass="game-description"
                                       text="Lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est."/>

                                <Label wrapText="true"
                                       styleClass="game-description"
                                       text="Lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est."/>

                            </VBox>
                        </VBox>

                        <!-- RIGHT PANEL -->
                        <VBox GridPane.columnIndex="1"
                              spacing="24.0"
                              styleClass="game-right-panel">

                            <padding>
                                <Insets top="35.0"
                                        right="40.0"
                                        bottom="35.0"
                                        left="40.0"/>
                            </padding>

                            <Label text="GAME"
                                   styleClass="game-title"/>

                            <!-- TAGS -->
                            <VBox spacing="10.0">

                                <HBox spacing="10.0">
                                    <Label text="Tag-1" styleClass="tag"/>
                                    <Label text="Tag-2" styleClass="tag"/>
                                    <Label text="Tag-3" styleClass="tag"/>
                                </HBox>

                                <HBox spacing="10.0">
                                    <Label text="Tag-4" styleClass="tag"/>
                                    <Label text="Tag-5" styleClass="tag"/>
                                </HBox>

                            </VBox>

                            <!-- INFO -->
                            <VBox spacing="14.0">

                                <Label text="Title: GAME"
                                       styleClass="game-info"/>

                                <Label text="Genre: Genre"
                                       styleClass="game-info"/>

                                <Label text="Developer: Developer"
                                       styleClass="game-info"/>

                            </VBox>

                            <!-- BUTTONS -->
                            <HBox spacing="18.0">

                                <Button text="Play"
                                        styleClass="game-play-button"/>

                                <Button text="Download"
                                        styleClass="game-download-button"/>

                            </HBox>

                        </VBox>

                    </GridPane>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>