<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="root"
            prefHeight="850.0"
            prefWidth="1400.0"
            styleClass="game-root"
            stylesheets="@../styles/styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.ies.fenix.client.controller.GameController">

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="main-scroll">

            <content>
                <VBox spacing="0.0"
                      styleClass="game-container">

                    <!-- BIG BANNER -->
                    <HBox alignment="CENTER"
                          prefHeight="360.0"
                          styleClass="game-banner-wrapper">

                        <ImageView fx:id="selectedGameBannerImage"
                                   fitHeight="320.0"
                                   fitWidth="1200.0"
                                   preserveRatio="false"
                                   styleClass="game-banner-image"/>
                    </HBox>

                    <!-- LOWER CONTENT -->
                    <GridPane styleClass="game-main-grid"
                              hgap="0.0"
                              vgap="0.0">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="68.0"/>
                            <ColumnConstraints percentWidth="32.0"/>
                        </columnConstraints>

                        <!-- LEFT PANEL -->
                        <VBox GridPane.columnIndex="0"
                              spacing="24.0"
                              styleClass="game-left-panel">

                            <padding>
                                <Insets top="35.0"
                                        right="40.0"
                                        bottom="35.0"
                                        left="40.0"/>
                            </padding>

                            <Label fx:id="selectedGameMainQuote"
                                   text="GAME"
                                   styleClass="game-main-quote"/>

                            <VBox spacing="18.0">

                                <Label fx:id="selectedGameDescription1"
                                       wrapText="true"
                                       styleClass="game-description"
                                       text="Game description"/>

                                <Label fx:id="selectedGameDescription2"
                                       wrapText="true"
                                       styleClass="game-description"/>

                                <Label fx:id="selectedGameDescription3"
                                       wrapText="true"
                                       styleClass="game-description"/>

                            </VBox>
                        </VBox>

                        <!-- RIGHT PANEL -->
                        <VBox GridPane.columnIndex="1"
                              spacing="24.0"
                              styleClass="game-right-panel">

                            <padding>
                                <Insets top="35.0"
                                        right="40.0"
                                        bottom="35.0"
                                        left="40.0"/>
                            </padding>

                            <Label fx:id="selectedGameTitle"
                                   text="GAME"
                                   styleClass="game-title"/>

                            <!-- TAGS -->
                            <VBox fx:id="tagContainerFather"
                                  spacing="10.0"/>

                            <!-- INFO -->
                            <VBox spacing="14.0">

                                <Label fx:id="selectedGameTitle2"
                                       text="Title: GAME"
                                       styleClass="game-info"/>

                                <Label fx:id="selectedGameDeveloper"
                                       text="Developer: Developer"
                                       styleClass="game-info"/>

                            </VBox>

                            <!-- BUTTONS -->
                            <HBox spacing="18.0">
                                <Button text="Play"
                                        styleClass="game-play-button"/>

                                <Button text="Download"
                                        styleClass="game-download-button"
                                        onAction="#onDownload"/>
                            </HBox>

                        </VBox>

                    </GridPane>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>