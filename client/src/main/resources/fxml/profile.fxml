<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="root"
            prefHeight="800.0"
            prefWidth="1300.0"
            styleClass="profile-root"
            stylesheets="@../styles/styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.ies.fenix.client.controller.ProfileController">

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="main-scroll">

            <content>
                <VBox spacing="28.0"
                      styleClass="profile-container">

                    <padding>
                        <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
                    </padding>

                    <!-- TITLE -->
                    <Label text="USER PROFILE"
                           styleClass="profile-section-title"/>

                    <!-- MAIN CARD -->
                    <GridPane styleClass="profile-main-card"
                              hgap="0.0"
                              vgap="0.0">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="25.0"/>
                            <ColumnConstraints percentWidth="32.0"/>
                            <ColumnConstraints percentWidth="43.0"/>
                        </columnConstraints>

                        <!-- LEFT: PROFILE IMAGE -->
                        <VBox GridPane.columnIndex="0"
                              alignment="CENTER"
                              spacing="28.0"
                              maxWidth="Infinity"
                              styleClass="profile-left-panel">

                            <padding>
                                <Insets top="35.0" right="30.0" bottom="35.0" left="30.0"/>
                            </padding>

                            <StackPane prefWidth="180.0"
                                       prefHeight="180.0"
                                       minWidth="180.0"
                                       minHeight="180.0"
                                       maxWidth="180.0"
                                       maxHeight="180.0"
                                       styleClass="profile-avatar-wrapper">

                                <FontIcon fx:id="profileIcon"
                                          iconLiteral="mdi2a-account-outline"
                                          iconSize="180"
                                          iconColor="#C6C6C6"/>

                                <ImageView fx:id="profileImage"
                                           fitWidth="180.0"
                                           fitHeight="180.0"
                                           preserveRatio="true"
                                           visible="false"/>
                            </StackPane>

                            <Button text="EDIT"
                                    styleClass="profile-edit-button"
                                    contentDisplay="RIGHT"
                                    onAction="#uploadProfilePicture"
                                    graphicTextGap="4">
                                <graphic>
                                    <FontIcon iconLiteral="mdi2p-play"
                                              iconSize="13"
                                              iconColor="WHITE"/>
                                </graphic>
                            </Button>
                        </VBox>

                        <!-- CENTER: IMPORTANT DATA -->
                        <VBox GridPane.columnIndex="1"
                              alignment="CENTER"
                              spacing="22.0"
                              maxWidth="Infinity"
                              styleClass="profile-center-panel">

                            <padding>
                                <Insets top="40.0" right="35.0" bottom="35.0" left="35.0"/>
                            </padding>

                            <VBox spacing="8.0"
                                  maxWidth="Infinity">
                                <Label text="Name"
                                       styleClass="profile-label"/>

                                <TextField fx:id="nameField"
                                           promptText="[USER-NAME]"
                                           editable="false"
                                           maxWidth="Infinity"
                                           styleClass="profile-input"/>
                            </VBox>

                            <VBox spacing="8.0"
                                  maxWidth="Infinity">
                                <Label text="Email"
                                       styleClass="profile-label"/>

                                <TextField fx:id="emailField"
                                           promptText="user@gmail.com"
                                           editable="false"
                                           maxWidth="Infinity"
                                           styleClass="profile-input"/>
                            </VBox>

                            <VBox spacing="8.0"
                                  maxWidth="Infinity">
                                <Label text="Password"
                                       styleClass="profile-label"/>

                                <PasswordField fx:id="passwordField"
                                               promptText="esto es una contraseña"
                                               editable="false"
                                               maxWidth="Infinity"
                                               styleClass="profile-input"/>
                            </VBox>
                        </VBox>

                        <!-- RIGHT: DESCRIPTION -->
                        <VBox GridPane.columnIndex="2"
                              alignment="CENTER"
                              spacing="22.0"
                              maxWidth="Infinity"
                              styleClass="profile-right-panel">

                            <padding>
                                <Insets top="40.0" right="35.0" bottom="35.0" left="35.0"/>
                            </padding>

                            <VBox spacing="8.0"
                                  maxWidth="Infinity">
                                <Label text="Description"
                                       styleClass="profile-label"/>

                                <TextArea fx:id="bio"
                                          wrapText="true"
                                          prefHeight="220.0"
                                          maxWidth="Infinity"
                                          promptText="Lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est."
                                          styleClass="profile-description"/>
                            </VBox>

                            <Button text="EDIT"
                                    onAction="#updateProfileBio"
                                    styleClass="profile-edit-button"
                                    contentDisplay="RIGHT"
                                    graphicTextGap="4">
                                <graphic>
                                    <FontIcon iconLiteral="mdi2p-play"
                                              iconSize="13"
                                              iconColor="WHITE"/>
                                </graphic>
                            </Button>
                        </VBox>

                    </GridPane>

                    <!-- OVERVIEW -->
                    <HBox spacing="28.0">

                        <HBox HBox.hgrow="ALWAYS"
                              alignment="CENTER_LEFT"
                              spacing="20.0"
                              styleClass="profile-overview-card">

                            <padding>
                                <Insets top="24.0" right="28.0" bottom="24.0" left="28.0"/>
                            </padding>

                            <HBox alignment="CENTER"
                                  styleClass="profile-overview-icon">
                                <FontIcon iconLiteral="mdi2g-gamepad-outline"
                                          iconSize="34"
                                          iconColor="#D3D3D3"/>
                            </HBox>

                            <VBox spacing="6.0"
                                  alignment="CENTER_LEFT"
                                  HBox.hgrow="ALWAYS">
                                <Label text="Games acquired"
                                       styleClass="profile-overview-title"/>

                                <Label fx:id="gamesAcquiredValue"
                                       text="0"
                                       styleClass="profile-overview-value"/>
                            </VBox>
                        </HBox>

                        <HBox HBox.hgrow="ALWAYS"
                              alignment="CENTER_LEFT"
                              spacing="20.0"
                              styleClass="profile-overview-card">

                            <padding>
                                <Insets top="24.0" right="28.0" bottom="24.0" left="28.0"/>
                            </padding>

                            <HBox alignment="CENTER"
                                  styleClass="profile-overview-icon">
                                <FontIcon iconLiteral="mdi2b-brush-outline"
                                          iconSize="34"
                                          iconColor="#D3D3D3"/>
                            </HBox>

                            <VBox spacing="6.0"
                                  alignment="CENTER_LEFT"
                                  HBox.hgrow="ALWAYS">
                                <Label text="Games created"
                                       styleClass="profile-overview-title"/>

                                <Label fx:id="gamesCreatedValue"
                                       text="0"
                                       styleClass="profile-overview-value"/>
                            </VBox>
                        </HBox>

                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>