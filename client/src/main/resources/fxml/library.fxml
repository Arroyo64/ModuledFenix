<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.control.Hyperlink?>

<BorderPane fx:id="root"
            prefHeight="800.0"
            prefWidth="1300.0"
            styleClass="library-root"
            stylesheets="@../styles/styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.ies.fenix.client.controller.LibraryController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="content-container">
            <padding>
                <Insets top="30.0" right="30.0" bottom="0.0" left="30.0"/>
            </padding>

            <Button styleClass="nav-button">
                <graphic>
                    <FontIcon iconLiteral="mdi2c-chevron-left" iconSize="22" iconColor="#9A9A9A"/>
                </graphic>
            </Button>

            <Button styleClass="nav-button">
                <graphic>
                    <FontIcon iconLiteral="mdi2c-chevron-right" iconSize="22" iconColor="#9A9A9A"/>
                </graphic>
            </Button>

            <Hyperlink text="MARKET PLACE" styleClass="tab-inactive" onAction="#switchToMarketplaceScene"/>
            <Hyperlink text="LIBRARY" styleClass="tab-active" onAction="#reloadView"/>
            <Hyperlink fx:id="username" text="USERNAME" styleClass="tab-inactive" onAction="#switchProfileScene"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Create your own visual novel" styleClass="main-action-button"/>

            <StackPane prefWidth="40"
                       prefHeight="40"
                       minWidth="40"
                       minHeight="40"
                       maxWidth="40"
                       maxHeight="40"
                       styleClass="profile-wrapper">

                <!-- Icono por defecto -->
                <FontIcon fx:id="topProfileIcon"
                          iconLiteral="mdi2a-account-outline"
                          iconSize="22"
                          iconColor="#B8B8B8"/>

                <!-- Imagen -->
                <ImageView fx:id="topProfileImage"
                           fitWidth="40"
                           fitHeight="40"
                           preserveRatio="true"
                           visible="false"/>
            </StackPane>

            <Label styleClass="dropdown-icon">
                <graphic>
                    <FontIcon iconLiteral="mdi2c-chevron-down" iconSize="18" iconColor="#9A9A9A"/>
                </graphic>
            </Label>
        </HBox>
    </top>

    <center>
        <HBox spacing="0.0" styleClass="library-main-container">

            <VBox prefWidth="360.0"
                  minWidth="360.0"
                  maxWidth="360.0"
                  styleClass="library-left-panel">

                <padding>
                    <Insets top="20.0" right="15.0" bottom="20.0" left="20.0"/>
                </padding>

                <HBox alignment="CENTER_LEFT" styleClass="library-search-wrapper">
                    <TextField fx:id="searchField"
                               promptText="Search"
                               HBox.hgrow="ALWAYS"
                               styleClass="library-search-field"/>
                    <Label text="≡" styleClass="library-filter-icon"/>
                </HBox>

                <ScrollPane fitToWidth="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            VBox.vgrow="ALWAYS"
                            styleClass="library-left-scroll">
                    <content>
                        <VBox fx:id="leftGamesList"
                              spacing="22.0"
                              styleClass="library-left-games-list">

                            <padding>
                                <Insets top="28.0" right="5.0" bottom="20.0" left="0.0"/>
                            </padding>

                            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="library-left-game-row">
                                <HBox alignment="CENTER" styleClass="library-left-game-icon-wrapper">
                                    <ImageView fitWidth="36.0" fitHeight="36.0" preserveRatio="true" styleClass="library-left-game-image"/>
                                </HBox>
                                <Label text="Game" styleClass="library-left-game-title"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="library-left-game-row">
                                <HBox alignment="CENTER" styleClass="library-left-game-icon-wrapper">
                                    <ImageView fitWidth="36.0" fitHeight="36.0" preserveRatio="true" styleClass="library-left-game-image"/>
                                </HBox>
                                <Label text="Game" styleClass="library-left-game-title"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="library-left-game-row">
                                <HBox alignment="CENTER" styleClass="library-left-game-icon-wrapper">
                                    <ImageView fitWidth="36.0" fitHeight="36.0" preserveRatio="true" styleClass="library-left-game-image"/>
                                </HBox>
                                <Label text="Game" styleClass="library-left-game-title"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="library-left-game-row">
                                <HBox alignment="CENTER" styleClass="library-left-game-icon-wrapper">
                                    <ImageView fitWidth="36.0" fitHeight="36.0" preserveRatio="true" styleClass="library-left-game-image"/>
                                </HBox>
                                <Label text="Game" styleClass="library-left-game-title"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="library-left-game-row">
                                <HBox alignment="CENTER" styleClass="library-left-game-icon-wrapper">
                                    <ImageView fitWidth="36.0" fitHeight="36.0" preserveRatio="true" styleClass="library-left-game-image"/>
                                </HBox>
                                <Label text="Game" styleClass="library-left-game-title"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="library-left-game-row">
                                <HBox alignment="CENTER" styleClass="library-left-game-icon-wrapper">
                                    <ImageView fitWidth="36.0" fitHeight="36.0" preserveRatio="true" styleClass="library-left-game-image"/>
                                </HBox>
                                <Label text="Game" styleClass="library-left-game-title"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="library-left-game-row">
                                <HBox alignment="CENTER" styleClass="library-left-game-icon-wrapper">
                                    <ImageView fitWidth="36.0" fitHeight="36.0" preserveRatio="true" styleClass="library-left-game-image"/>
                                </HBox>
                                <Label text="Game" styleClass="library-left-game-title"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="library-left-game-row">
                                <HBox alignment="CENTER" styleClass="library-left-game-icon-wrapper">
                                    <ImageView fitWidth="36.0" fitHeight="36.0" preserveRatio="true" styleClass="library-left-game-image"/>
                                </HBox>
                                <Label text="Game" styleClass="library-left-game-title"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="library-left-game-row">
                                <HBox alignment="CENTER" styleClass="library-left-game-icon-wrapper">
                                    <ImageView fitWidth="36.0" fitHeight="36.0" preserveRatio="true" styleClass="library-left-game-image"/>
                                </HBox>
                                <Label text="Game" styleClass="library-left-game-title"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="library-left-game-row">
                                <HBox alignment="CENTER" styleClass="library-left-game-icon-wrapper">
                                    <ImageView fitWidth="36.0" fitHeight="36.0" preserveRatio="true" styleClass="library-left-game-image"/>
                                </HBox>
                                <Label text="Game" styleClass="library-left-game-title"/>
                            </HBox>

                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        HBox.hgrow="ALWAYS"
                        styleClass="library-right-scroll">
                <content>
                    <GridPane fx:id="libraryGrid"
                              hgap="18.0"
                              vgap="24.0"
                              styleClass="library-grid">

                        <padding>
                            <Insets top="70.0" right="28.0" bottom="30.0" left="28.0"/>
                        </padding>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="2" GridPane.rowIndex="1">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="3" GridPane.rowIndex="1">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="2" GridPane.rowIndex="2">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                        <StackPane styleClass="library-card-click-wrapper" GridPane.columnIndex="3" GridPane.rowIndex="2">
                            <VBox styleClass="library-card">
                                <HBox alignment="CENTER" styleClass="library-cover-wrapper">
                                    <ImageView fitWidth="170.0" fitHeight="245.0" preserveRatio="true" styleClass="library-cover-image"/>
                                </HBox>
                            </VBox>
                            <Button prefWidth="230.0" prefHeight="285.0" styleClass="invisible-game-button"/>
                        </StackPane>

                    </GridPane>
                </content>
            </ScrollPane>

        </HBox>
    </center>
</BorderPane>